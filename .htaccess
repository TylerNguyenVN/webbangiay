RewriteEngine On
RewriteBase /webbangiay/

# Nếu request là file/thư mục thật → phục vụ trực tiếp
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rewrite các file .html và cart.php vào /views/
RewriteRule ^(index\.html|san-pham\.html|product-detail\.html|cart\.php|admin\.html|auth\.html|profile\.html|wishlist\.html)$ views/$1 [L]
